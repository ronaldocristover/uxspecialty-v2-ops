# ── MySQL Configuration ───────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=uxspecialty_db
MYSQL_USER=uxspecialty_user
MYSQL_PASSWORD=change_me_mysql_password

# ── Backend API ───────────────────────────────────────────────
# Database connection
DATABASE_URL=mysql://uxspecialty_user:change_me_mysql_password@mysql:3306/uxspecialty_db

# JWT
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=24h

# App URLs
APP_URL=https://uxspecialty.com
API_URL=https://api.uxspecialty.com
ADMIN_URL=https://admin.uxspecialty.com

# Environment
NODE_ENV=production
PORT=3000

# ── Portal (Next.js) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.uxspecialty.com

# ── Admin Dashboard (Vue) ────────────────────────────────────
VITE_API_URL=https://api.uxspecialty.com
